# ---- Lethe configuration ------------------------------------------------
# Copy to `.env` and fill in. Lethe runs fully without any of these (local
# memory backend + heuristic judge), but real keys unlock the Cognee Cloud
# path and the LLM-based auditor/judge.

# Memory backend: auto | cognee | local
LETHE_MEMORY_BACKEND=auto

# --- Cognee Cloud (unlocks the "Best Use of Cognee Cloud" track) ---
# From the Cognee Cloud dashboard "API Keys" page (apply code COGNEE-35).
# Lethe talks to Cognee Cloud over REST when BOTH of these are set, so it
# works on any Python version (no SDK needed).
COGNEE_API_KEY=
# Your tenant base URL, e.g. https://your-tenant.aws.cognee.ai
COGNEE_API_URL=

# Cognee's own LLM provider key (used by cognify/recall inside Cognee):
# LLM_API_KEY=
# OPENAI_API_KEY=

# --- LLM judge + grounded recall (Anthropic API) ---
ANTHROPIC_API_KEY=
LETHE_JUDGE_MODEL=claude-sonnet-4-6

# --- Certificate signing (rotate in production; keep secret) ---
LETHE_SIGNING_SECRET=change-me-to-a-long-random-string
LETHE_ISSUER=Lethe Compliance Engine v2

# --- Runtime ---
LETHE_PROBE_CONCURRENCY=5
